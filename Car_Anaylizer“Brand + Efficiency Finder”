public class Car_Anaylzer"Brand + Efficency Finder" {

	public static void main(String[] args) {
 import java.io.File;
import java.util.ArrayList;
import java.util.Scanner;

class Car {
    private String carID;
    private String brand;
    private String model;
    private int year;
    private String fuelType;
    private String color;
    private double mileage;

    public Car(String carID, String brand, String model, int year, String fuelType, String color, double mileage) {
        this.carID = carID;
        this.brand = brand;
        this.model = model;
        this.year = year;
        this.fuelType = fuelType;
        this.color = color;
        this.mileage = mileage;
    }

    public String getBrand() { return brand; }
    public String getFuelType() { return fuelType; }
    public double getMileage() { return mileage; }

    @Override
    public String toString() {
        return String.format("%-5s | %-10s | %-10s | %d | %-8s | %-8s | %,.1f", 
                carID, brand, model, year, fuelType, color, mileage);
    }
}

public class CarProject {
    private static ArrayList<Car> carList = new ArrayList<>();

    public static void main(String[] args) {
        loadCSV("cars.csv"); // STEP 2
        runMenu();           // STEP 6
    }

    public static void loadCSV(String fileName) {
        try (Scanner fileScanner = new Scanner(new File(fileName))) {
            if (fileScanner.hasNextLine()) fileScanner.nextLine(); // Skip header
            while (fileScanner.hasNextLine()) {
                String[] data = fileScanner.nextLine().split(",");
                carList.add(new Car(data[0], data[1], data[2], 
                        Integer.parseInt(data[3]), data[4], data[5], 
                        Double.parseDouble(data[6])));
            }
            System.out.println("Successfully loaded " + carList.size() + " cars.");
        } catch (Exception e) {
            System.out.println("Error loading file: " + e.getMessage());
        }
    }

    public static void selectionSortByBrand() {
        for (int i = 0; i < carList.size() - 1; i++) {
            int minIdx = i;
            for (int j = i + 1; j < carList.size(); j++) {
                if (carList.get(j).getBrand().compareToIgnoreCase(carList.get(minIdx).getBrand()) < 0) {
                    minIdx = j;
                }
            }
            Car temp = carList.get(i);
            carList.set(i, carList.get(minIdx));
            carList.set(minIdx, temp);
        }
        System.out.println("List sorted by Brand.");
    }

    public static void binarySearchBrand(String target) {
        selectionSortByBrand(); // Must be sorted first
        int low = 0, high = carList.size() - 1;
        boolean found = false;
        while (low <= high) {
            int mid = (low + high) / 2;
            int cmp = carList.get(mid).getBrand().compareToIgnoreCase(target);
            if (cmp == 0) {
                System.out.println("Found: " + carList.get(mid));
                found = true; break;
            } else if (cmp < 0) low = mid + 1;
            else high = mid - 1;
        }
        if (!found) System.out.println("Brand '" + target + "' not found.");
    }

    public static void showStats() {
        if (carList.isEmpty()) return;
        double totalMileage = 0;
        int electricCount = 0;
        for (Car c : carList) {
            totalMileage += c.getMileage();
            if (c.getFuelType().equalsIgnoreCase("Electric")) electricCount++;
        }
        System.out.printf("Average Mileage: %,.2f\n", (totalMileage / carList.size()));
        System.out.println("Number of Electric Cars: " + electricCount);
    }

    public static void runMenu() {
        Scanner input = new Scanner(System.in);
        int choice = 0;
        while (choice != 5) {
            System.out.println("\n--- Car Management System ---");
            System.out.println("1. Display All Cars\n2. Sort by Brand\n3. Search for Brand\n4. Show Stats\n5. Exit");
            System.out.print("Enter choice: ");
            choice = input.nextInt();
            input.nextLine();

            switch (choice) {
                case 1: for (Car c : carList) System.out.println(c); break;
                case 2: selectionSortByBrand(); break;
                case 3: 
                    System.out.print("Enter Brand to search: ");
                    binarySearchBrand(input.nextLine());
                    break;
                case 4: showStats(); break;
                case 5: System.out.println("Exiting..."); break;
                default: System.out.println("Invalid choice.");
            		}
        		}
    		}
		}
	}
}